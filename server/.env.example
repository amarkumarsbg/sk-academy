PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/sk-academy
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000
UPLOAD_DIR=uploads
ADMIN_EMAIL=admin@skacademy.edu
ADMIN_PASSWORD=admin1234

# Email notifications (optional — forms still save to DB without this)
NOTIFY_EMAIL=admissions@skacademy.edu
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="SK Academy <noreply@skacademy.edu>"

# Cloudflare Turnstile CAPTCHA (optional)
TURNSTILE_SECRET_KEY=

# Cloudinary image/document storage (recommended for production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Production (Render):
# - Set MONGODB_URI to your Atlas connection string
# - Set CLIENT_URL to your Vercel URL (no trailing slash)
# - Use a strong JWT_SECRET and ADMIN_PASSWORD
# - NODE_ENV=production is set automatically on Render
