# Next.js — copy to .env.local for local dev
# On Vercel: add API_URL in Project → Settings → Environment Variables

API_URL=http://localhost:4000

# Optional: public site URL for sitemap (production)
CLIENT_URL=http://localhost:3000

# Optional: Cloudflare Turnstile site key for contact/admission forms
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
