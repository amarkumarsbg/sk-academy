PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/sk-academy
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000
ADMIN_URL=
UPLOAD_DIR=uploads
ADMIN_EMAIL=admin@skacademy.edu
ADMIN_PASSWORD=admin1234

# Email notifications — contact/admission form alerts go here
NOTIFY_EMAIL=info@skacademy.net
MAIL_FROM="SK Academy Website <noreply@skacademy.net>"
EMAIL_PROVIDER=smtp

# Resend (optional) — verify your domain at resend.com/domains
RESEND_API_KEY=
RESEND_FROM="SK Academy Website <noreply@skacademy.net>"

# GoDaddy Titan SMTP
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_USER=info@skacademy.net
SMTP_PASS=your-titan-email-password

# Cloudflare Turnstile CAPTCHA (optional)
TURNSTILE_SECRET_KEY=

# Cloudinary image/document storage (recommended for production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Production (Render):
# - Set MONGODB_URI to your Atlas connection string
# - Set CLIENT_URL to your Vercel URL (no trailing slash)
# - Use a strong JWT_SECRET and ADMIN_PASSWORD
# - NODE_ENV=production is set automatically on Render
